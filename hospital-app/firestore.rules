rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow read/write to careCenters. Tighten with request.auth != null if you add Firebase Auth.
    match /careCenters/{docId} {
      allow read, write: if true;
    }
    // Manual wait overrides (iOS listens here). Doc ID = care center UUID.
    match /adminWaitTimeOverrides/{docId} {
      allow read, write: if true;
    }
  }
}
